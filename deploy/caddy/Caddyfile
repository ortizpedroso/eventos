# Reverse proxy — HTTPS automático (Let's Encrypt).
# Defina no .env: DOMAIN=seudominio.com.br  ACME_EMAIL=admin@seudominio.com.br
#
# /api/* → API FastAPI (pagamentos, webhooks Asaas/Stripe)
# /health e /ready → readiness/liveness para monitoramento externo
# resto → Next.js

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	@health path /health /ready
	handle @health {
		reverse_proxy api:8000
	}

	@api path /api/*
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
