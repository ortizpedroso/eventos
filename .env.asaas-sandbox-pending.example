# Copie para .env.asaas-sandbox-pending (gitignored) com credenciais SANDBOX do painel Asaas.
# Usado por: ./scripts/switch-asaas-sandbox.sh
# Testar após alternar: ./scripts/test-asaas-sandbox.sh
#
# Obtenha em https://sandbox.asaas.com → Integrações → API Key
# walletId: Minha conta → dados da conta (ou GET /v3/myAccount)

PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=$aact_hmlg_...
ASAAS_PLATFORM_WALLET_ID=uuid-wallet-plataforma-sandbox
# Token = mesmo valor no painel Asaas SANDBOX → Webhooks → Token de autenticação
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENVIRONMENT=sandbox
ASAAS_DISABLED=false

# Modo linked (padrão produção): organizador cola walletId próprio
ASAAS_ONBOARDING_MODE=linked
# true = permite vincular wallet manual no Financeiro (recomendado em sandbox sem BaaS PJ)
ASAAS_ALLOW_MANUAL_WALLET=true
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false
