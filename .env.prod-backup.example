# Copie para .env.prod-backup (gitignored) com TODAS as credenciais de produção do VPS.
# Gerado automaticamente por: ./scripts/backup-prod-env.sh
# Restaurar: ./scripts/restore-prod-env.sh [--reload]
# Verificar: ./scripts/verify-prod-backup.sh
#
# NUNCA commitar o arquivo real (.env.prod-backup).

DOMAIN=eventosbr.app.br
ACME_EMAIL=admin@eventosbr.app.br
NEXT_PUBLIC_API_URL=https://eventosbr.app.br
FRONTEND_PUBLIC_URL=https://eventosbr.app.br
NEXT_PUBLIC_PAYMENT_PROVIDER=asaas

POSTGRES_PASSWORD=senha-forte-postgres

PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=$aact_prod_COLE_SUA_CHAVE_AQUI
ASAAS_PLATFORM_WALLET_ID=uuid-wallet-plataforma-producao
ASAAS_WEBHOOK_TOKEN=token-forte-webhook
ASAAS_ENVIRONMENT=production
ASAAS_DISABLED=false
ASAAS_ONBOARDING_MODE=linked
ASAAS_ALLOW_MANUAL_WALLET=false
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false

SECRET_KEY=secret-key-minimo-32-caracteres-aleatorios
PLATFORM_ADMIN_API_KEY=admin-api-key-forte

EMAIL_SERVER=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=noreply@eventosbr.app.br
EMAIL_PASSWORD=senha-smtp
EMAIL_FROM_NAME=EventosBR
EMAIL_USE_TLS=true

REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true
TICKET_EMAIL_MAX_ATTEMPTS=3

CORS_ORIGINS=https://eventosbr.app.br,https://www.eventosbr.app.br
TRUST_FORWARDED_HEADERS=true
ENVIRONMENT=production
DEBUG=False

# Opcionais
# GOOGLE_OAUTH_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# MARKETING_WHATSAPP_WEBHOOK_URL=
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=
# BACKUP_OFFSITE_TARGET=
