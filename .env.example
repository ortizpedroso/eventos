# Database
DATABASE_URL=postgresql+psycopg2://eventosbr:eventosbr@localhost:5432/eventosbr

# Pagamentos — Asaas
PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# sandbox | production (vazio = infere pela chave $aact_prod_)
ASAAS_ENVIRONMENT=
ASAAS_DISABLED=false
# walletId da conta EventosBR para split da taxa (painel Asaas → Minha conta)
ASAAS_PLATFORM_WALLET_ID=
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false
# Produção: false (subconta obrigatória). Dev/test: pode omitir (default permite wallet manual).
ASAAS_ALLOW_MANUAL_WALLET=
ASAAS_ONBOARDING_MODE=baas
# Carência (horas) após confirmação do pagamento antes de liberar saque
FINANCEIRO_CARENCIA_SAQUE_HORAS=48
# Prazo máximo informado ao organizador para conclusão da transferência Pix
FINANCEIRO_PRAZO_TRANSFERENCIA_HORAS=48

# OAuth — login com Google (frontend lê GET /api/auth/oauth-config)
# Google Cloud → Credentials → OAuth 2.0 Client ID (Web) → origens http://localhost:3000
# GOOGLE_OAUTH_CLIENT_ID=123....apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=

# JWT
SECRET_KEY=sua-chave-secreta-muito-segura-aqui-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
EMAIL_FROM_NAME=EventosBR
EMAIL_USE_TLS=true
FRONTEND_PUBLIC_URL=http://localhost:3000

# Redis (rate limit em produção; opcional — fallback em memória se indisponível)
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true
TICKET_EMAIL_MAX_ATTEMPTS=3

# CORS (separe por vírgula; nunca use * em produção com dados reais)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# Reverse proxy: só true se a API estiver atrás de proxy que define X-Forwarded-For de forma fidedigna
TRUST_FORWARDED_HEADERS=false

# Admin plataforma — exportar opt-in de marketing (cabeçalho X-Platform-Admin-Key). Gere uma chave longa e secreta.
# PLATFORM_ADMIN_API_KEY=
# MARKETING_WHATSAPP_WEBHOOK_URL=https://seu-servico/whatsapp/send
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=token-secreto-enviado-no-header-authorization

# Frontend (ver também frontend/.env.local.example)
# NEXT_PUBLIC_PAYMENT_PROVIDER=asaas
# NEXT_PUBLIC_EMAIL_CONTATO=contato@exemplo.com
# NEXT_PUBLIC_EMAIL_DENUNCIAS=denuncias@exemplo.com

# Ambiente (development = OpenAPI em /docs + create_tables local; production no deploy)
DEBUG=True
ENVIRONMENT=development

# Rodapé — URLs das redes (opcional; ícones usam # se vazio)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/seu_perfil
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/...
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://youtube.com/@...
