# Database (Postgres em produção; SQLite possível em dev local)
DATABASE_URL=postgresql+psycopg2://eventosbr:eventosbr@localhost:5432/eventosbr

# Stripe (sk_test_/pk_test_ em dev; sk_live_/pk_live_ só em produção)
# Nunca commite o arquivo .env real.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Dev local: .\scripts\stripe-webhook-setup.ps1 + .\scripts\stripe-webhook-dev.ps1
STRIPE_DISABLED=false
# true = organizador cadastra sem Account Connect (até aceitar termos no Dashboard)
STRIPE_SKIP_CONNECT_ON_REGISTER=false

# OAuth — login com Google (frontend lê GET /api/auth/oauth-config)
GOOGLE_OAUTH_CLIENT_ID=

# JWT
SECRET_KEY=sua-chave-secreta-muito-segura-aqui-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin plataforma (cabeçalho X-Platform-Admin-Key no painel /admin)
# PLATFORM_ADMIN_API_KEY=

# Email
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
EMAIL_FROM_NAME=EventosBR
FRONTEND_PUBLIC_URL=http://localhost:3000

# Redis (rate limit; fallback em memória se indisponível)
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true
TICKET_EMAIL_MAX_ATTEMPTS=3

# CORS (separe por vírgula; nunca use * em produção)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# Reverse proxy: true só atrás de Caddy/nginx fidedigno
TRUST_FORWARDED_HEADERS=false

# Ambiente (development = OpenAPI em /docs + create_tables local)
DEBUG=True
ENVIRONMENT=development

# Portaria (opcional)
# PORTARIA_TOKEN_MAX_AGE_DAYS=90
# PORTARIA_TOKEN_ROTATE_BEFORE_EVENT_DAYS=7

# Marketing WhatsApp (opcional)
# MARKETING_WHATSAPP_WEBHOOK_URL=
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=

# Frontend — ver também frontend/.env.local.example
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=...
# NEXT_PUBLIC_EMAIL_CONTATO=contato@exemplo.com
# NEXT_PUBLIC_EMAIL_DENUNCIAS=denuncias@exemplo.com
# NEXT_PUBLIC_LAN_ORIGIN=http://192.168.1.10

# Rodapé — redes sociais (opcional)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
