# Database
DATABASE_URL=postgresql+psycopg2://eventosbr:eventosbr@localhost:5432/eventosbr

# Stripe (use sk_test_/pk_test_ em desenvolvimento; sk_live_/pk_live_ só em produção)
# Nunca commite o arquivo .env real.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect: em Settings > Connect aceite os termos da plataforma (loss liability) antes de criar contas Express.
# Enquanto isso, o cadastro de organizador pode concluir sem conta conectada ou use STRIPE_DISABLED=true.
STRIPE_DISABLED=false
# true = organizador cadastra sem Account.create (só Customer). Útil até aceitar termos Connect no Dashboard.
STRIPE_SKIP_CONNECT_ON_REGISTER=false

# JWT
SECRET_KEY=sua-chave-secreta-muito-segura-aqui-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app

# Redis
REDIS_URL=redis://redis:6379

# CORS (separe por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Ambiente
DEBUG=False
ENVIRONMENT=production

# Rodapé — URLs das redes (opcional; ícones usam # se vazio)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/seu_perfil
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/...
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://youtube.com/@...
