# Frontend EventosBR — copie para .env.local (nunca commite .env.local)
# API: em dev o Next faz proxy de /api/* para a API (next.config.ts rewrites).

# URL pública da API (opcional em dev; padrão usa proxy /api no mesmo host)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Login social (mesmos IDs configurados na API: GOOGLE_OAUTH_CLIENT_ID / APPLE_OAUTH_CLIENT_ID)
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=123....apps.googleusercontent.com
# NEXT_PUBLIC_APPLE_OAUTH_CLIENT_ID=com.seudominio.web

# Stripe (mesma pk_test do .env da API)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# true = UI de pagamento desabilitada (testes sem Stripe)
# NEXT_PUBLIC_STRIPE_DISABLED=false

# Exibição opcional no rodapé / confiança na compra
# NEXT_PUBLIC_API_DISPLAY=http://localhost:8000
# NEXT_PUBLIC_EMAIL_CONTATO=contato@exemplo.com
# NEXT_PUBLIC_EMAIL_DENUNCIAS=denuncias@exemplo.com

# Redes sociais (opcional; ícones ocultos se vazio)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# Proxy interno (Docker / produção — normalmente definido no compose, não no .env.local)
# INTERNAL_API_URL=http://api:8000
# API_PROXY_TARGET=http://127.0.0.1:8000
