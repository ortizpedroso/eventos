# Copie para .env.local (não commite .env.local)

# URL interna da API (SSR / Route Handlers no servidor Next.js)
INTERNAL_API_URL=http://127.0.0.1:8000

# URL pública da API (usada pelo browser quando NEXT_PUBLIC_API_URL não é
# relativa; em dev com proxy Next.js pode deixar vazio para usar rotas /api/* locais)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Provedor de pagamento (sempre asaas)
NEXT_PUBLIC_PAYMENT_PROVIDER=asaas

# OAuth Google — mesmo Client ID configurado na API
# Google Cloud → Credentials → OAuth 2.0 Client ID (Web) → origens: http://localhost:3000
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=123....apps.googleusercontent.com

# Google Maps Embed — mapa na página do evento (Maps Embed API)
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=AIza...

# E-mails de contato exibidos na página de confiança
# NEXT_PUBLIC_EMAIL_CONTATO=contato@exemplo.com
# NEXT_PUBLIC_EMAIL_DENUNCIAS=denuncias@exemplo.com

# Rótulo exibido no rodapé ao lado da URL da API (ex.: "EventosBR API")
# NEXT_PUBLIC_API_DISPLAY=EventosBR API

# Redes sociais — rodapé (opcional; usa "#" se vazio)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/seu_perfil
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=https://linkedin.com/company/...
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/...
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://youtube.com/@...
