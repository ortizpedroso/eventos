# =============================================================================
# EventosBR — produção (VPS Hostinger)
#
# No servidor:
#   cp .env.production.example .env
#   ./scripts/generate-secrets.sh    # SECRET_KEY, PLATFORM_ADMIN_API_KEY, POSTGRES_PASSWORD
#   nano .env                        # domínio, Stripe live, SMTP
#
# Após pull com novas variáveis no exemplo:
#   ./scripts/update-env-vps.sh      # adiciona chaves faltantes sem apagar valores atuais
#
# Nunca commite o .env real.
# =============================================================================

# --- Domínio (Caddy + URLs públicas) ---
DOMAIN=eventosbr.app.br
ACME_EMAIL=admin@eventosbr.app.br
NEXT_PUBLIC_API_URL=https://eventosbr.app.br
FRONTEND_PUBLIC_URL=https://eventosbr.app.br
# Opcional: origem LAN para QR/link de portaria em tablet na rede local
# NEXT_PUBLIC_LAN_ORIGIN=http://192.168.1.10

# --- Postgres (serviço db no docker-compose.prod.yml) ---
# ATENÇÃO: definida só no PRIMEIRO deploy. Depois, mudar aqui exige
# ./scripts/sync-postgres-password-vps.sh (o deploy-vps.sh já faz isso automaticamente).
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI

# --- JWT / Admin plataforma ---
SECRET_KEY=GERE_COM_scripts/generate-secrets.sh
PLATFORM_ADMIN_API_KEY=GERE_COM_scripts/generate-secrets.sh

# --- Stripe LIVE (go-live) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...copie_do_dashboard_stripe_webhooks
STRIPE_DISABLED=false
# true = cadastro de organizador sem conta Connect (só até aceitar termos no Dashboard)
STRIPE_SKIP_CONNECT_ON_REGISTER=false

# --- OAuth Google (login social) ---
GOOGLE_OAUTH_CLIENT_ID=
# O build do Next usa o mesmo Client ID (docker-compose repassa automaticamente)

# --- E-mail transacional (Hostinger Email, Brevo, Resend, etc.) ---
EMAIL_SERVER=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=noreply@eventosbr.app.br
EMAIL_PASSWORD=
EMAIL_FROM_NAME=EventosBR

# --- Redis / filas (serviço redis no compose) ---
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true
TICKET_EMAIL_MAX_ATTEMPTS=3

# --- CORS (domínios HTTPS do site; nunca use *) ---
CORS_ORIGINS=https://eventosbr.app.br,https://www.eventosbr.app.br

# --- Proxy reverso (Caddy) ---
TRUST_FORWARDED_HEADERS=true
ENVIRONMENT=production
DEBUG=False

# --- Frontend (textos/links exibidos no site; alguns entram no build do container web) ---
# NEXT_PUBLIC_EMAIL_CONTATO=contato@eventosbr.com.br
# NEXT_PUBLIC_EMAIL_DENUNCIAS=denuncias@eventosbr.com.br
# NEXT_PUBLIC_API_DISPLAY=EventosBR API
# NEXT_PUBLIC_STRIPE_DISABLED=true
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
# NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
# NEXT_PUBLIC_SOCIAL_X_URL=
# NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=

# --- Portaria (opcional) ---
# PORTARIA_TOKEN_MAX_AGE_DAYS=90
# PORTARIA_TOKEN_ROTATE_BEFORE_EVENT_DAYS=7

# --- Marketing WhatsApp (opcional) ---
# MARKETING_WHATSAPP_WEBHOOK_URL=
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=
