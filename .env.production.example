# =============================================================================
# EventosBR — produção (VPS Hostinger)
# Copie para .env na raiz do servidor:  cp .env.production.example .env
# Nunca commite o .env real.
# =============================================================================

# --- Domínio (Caddy + URLs públicas) ---
DOMAIN=eventosbr.com.br
ACME_EMAIL=admin@eventosbr.com.br
NEXT_PUBLIC_API_URL=https://eventosbr.com.br
FRONTEND_PUBLIC_URL=https://eventosbr.com.br

# --- Postgres (serviço db no compose) ---
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI

# --- Pagamentos — Asaas (principal) ---
PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=$aact_prod_...
ASAAS_WEBHOOK_TOKEN=GERE_TOKEN_FORTE_PARA_WEBHOOK
ASAAS_ENVIRONMENT=production
ASAAS_DISABLED=false
# walletId da conta EventosBR (split da taxa) — painel Asaas → Minha conta
ASAAS_PLATFORM_WALLET_ID=
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false

# --- Stripe (legado / fallback se PAYMENT_PROVIDER=stripe) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...de_producao_dashboard_stripe
STRIPE_DISABLED=true
STRIPE_SKIP_CONNECT_ON_REGISTER=true

# --- OAuth (login Google) ---
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com

# --- JWT / Admin ---
SECRET_KEY=GERE_COM_scripts/generate-secrets.ps1
PLATFORM_ADMIN_API_KEY=GERE_COM_scripts/generate-secrets.ps1

# --- E-mail transacional (Hostinger Email, Brevo, etc.) ---
EMAIL_SERVER=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=noreply@eventosbr.com.br
EMAIL_PASSWORD=
EMAIL_FROM_NAME=EventosBR
EMAIL_USE_TLS=true

# --- Redis / filas ---
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true
TICKET_EMAIL_MAX_ATTEMPTS=3

# --- CORS (mesmo domínio do site; sem *) ---
CORS_ORIGINS=https://eventosbr.com.br,https://www.eventosbr.com.br

# --- Proxy (Caddy na frente) ---
TRUST_FORWARDED_HEADERS=true
ENVIRONMENT=production
DEBUG=False

# --- Opcional ---
# MARKETING_WHATSAPP_WEBHOOK_URL=
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=

# --- Backup automático (cron no VPS) ---
# BACKUP_DIR=./backups
# BACKUP_KEEP_DAYS=14
# BACKUP_LOG=./backups/backup.log
# Upload off-site (rclone, scp ou aws s3):
# BACKUP_OFFSITE_TARGET=s3:eventosbr-backups/postgres
# ou comando customizado:
# BACKUP_UPLOAD_CMD=rclone copy ./backups remote:eventosbr/postgres

# --- Monitoramento /ready ---
# MONITOR_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# MONITOR_ALERT_EMAIL=admin@eventosbr.com.br
