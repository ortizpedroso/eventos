# =============================================================================
# EventosBR — produção (VPS Hostinger) — domínio eventosbr.app.br
# Copie para .env na raiz do servidor:  cp .env.production.example .env
# =============================================================================

# --- Domínio (Caddy + URLs públicas) ---
DOMAIN=eventosbr.app.br
ACME_EMAIL=admin@eventosbr.app.br
NEXT_PUBLIC_API_URL=https://eventosbr.app.br
FRONTEND_PUBLIC_URL=https://eventosbr.app.br
NEXT_PUBLIC_PAYMENT_PROVIDER=asaas

# --- Marca / marketing (frontend) ---
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_WHATSAPP_URL=
NEXT_PUBLIC_EMAIL_CONTATO=contato@eventosbr.app.br
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# --- Postgres ---
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI

# --- Pagamentos — Asaas (principal) ---
PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=$aact_prod_...
ASAAS_WEBHOOK_TOKEN=GERE_TOKEN_FORTE_PARA_WEBHOOK
ASAAS_ENVIRONMENT=production
ASAAS_DISABLED=false
ASAAS_PLATFORM_WALLET_ID=
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false

# --- Stripe (legado) ---
STRIPE_DISABLED=true
STRIPE_SKIP_CONNECT_ON_REGISTER=true

# --- JWT / Admin ---
SECRET_KEY=GERE_COM_scripts/generate-secrets.ps1
PLATFORM_ADMIN_API_KEY=GERE_COM_scripts/generate-secrets.ps1

# --- E-mail ---
EMAIL_SERVER=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=noreply@eventosbr.app.br
EMAIL_PASSWORD=
EMAIL_FROM_NAME=EventosBR
EMAIL_USE_TLS=true

# --- Redis ---
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true

# --- CORS ---
CORS_ORIGINS=https://eventosbr.app.br,https://www.eventosbr.app.br

TRUST_FORWARDED_HEADERS=true
ENVIRONMENT=production
DEBUG=False

# Scripts: configure-asaas-env.sh, backup-postgres-cron.sh, monitor-ready.sh, verify-production.sh
# Docs: docs/11-go-live-asaas.md
