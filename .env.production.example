# =============================================================================
# EventosBR — produção (VPS Hostinger) — domínio eventosbr.app.br
# Copie para .env na raiz do servidor:  cp .env.production.example .env
# Gere secrets: ./scripts/generate-secrets.sh  (ou generate-secrets.ps1 no Windows)
# =============================================================================

# --- Domínio (Caddy + URLs públicas) ---
DOMAIN=eventosbr.app.br
ACME_EMAIL=admin@eventosbr.app.br
NEXT_PUBLIC_API_URL=https://eventosbr.app.br
FRONTEND_PUBLIC_URL=https://eventosbr.app.br
NEXT_PUBLIC_PAYMENT_PROVIDER=asaas

# --- Marca / marketing (frontend) ---
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_WHATSAPP_URL=
NEXT_PUBLIC_EMAIL_CONTATO=contato@eventosbr.app.br
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# --- OAuth (opcional — Google Sign In) ---
GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# --- Postgres ---
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI

# --- Pagamentos — Asaas (único provedor) ---
PAYMENT_PROVIDER=asaas
# Chaves Asaas contêm $ — no .env do VPS cada $ vira $$ (ex.: $$aact_prod_...)
ASAAS_API_KEY=$$aact_prod_...
ASAAS_WEBHOOK_TOKEN=GERE_TOKEN_FORTE_PARA_WEBHOOK
ASAAS_ENVIRONMENT=production
ASAAS_DISABLED=false
ASAAS_PLATFORM_WALLET_ID=
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false
ASAAS_ALLOW_MANUAL_WALLET=false
ASAAS_ONBOARDING_MODE=linked

# Backups Asaas (gitignored — ver exemplos na raiz):
#   .env.prod-backup               ← produção completa (backup-prod-env.sh)
#   .env.asaas-prod-backup         ← subset Asaas (gerado junto)
#   .env.asaas-sandbox-pending     ← sandbox (switch-asaas-sandbox.sh)
# Templates: .env.prod-backup.example, .env.asaas-prod-backup.example, .env.asaas-sandbox-pending.example

# --- JWT / Admin ---
SECRET_KEY=GERE_COM_scripts/generate-secrets.sh
PLATFORM_ADMIN_API_KEY=GERE_COM_scripts/generate-secrets.sh

# --- E-mail ---
EMAIL_SERVER=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USER=noreply@eventosbr.app.br
EMAIL_PASSWORD=
EMAIL_FROM_NAME=EventosBR
EMAIL_USE_TLS=true

# --- Redis ---
REDIS_URL=redis://redis:6379
RATE_LIMIT_USE_REDIS=true
TICKET_EMAIL_USE_REDIS=true

# --- CORS (inclua apex e www — Caddy redireciona www → apex) ---
CORS_ORIGINS=https://eventosbr.app.br,https://www.eventosbr.app.br

# --- Segurança / ambiente ---
TRUST_FORWARDED_HEADERS=true
ENVIRONMENT=production
DEBUG=False

# --- Opcional: marketing WhatsApp webhook ---
# MARKETING_WHATSAPP_WEBHOOK_URL=
# MARKETING_WHATSAPP_WEBHOOK_TOKEN=

# --- Opcional: backup off-site (scripts/backup-postgres-cron.sh) ---
# BACKUP_OFFSITE_TARGET=

# Scripts: configure-asaas-env.sh, backup-postgres-cron.sh, monitor-ready.sh, verify-production.sh
# Docs: docs/11-go-live-asaas.md, docs/08-deploy-hostinger.md
