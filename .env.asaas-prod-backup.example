# Copie para .env.asaas-prod-backup (gitignored) — subset Asaas (gerado por backup-prod-env.sh).
# Para backup COMPLETO use: ./scripts/backup-prod-env.sh → .env.prod-backup
# Template completo: .env.prod-backup.example

PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=$aact_prod_...
ASAAS_PLATFORM_WALLET_ID=uuid-wallet-plataforma-producao
ASAAS_WEBHOOK_TOKEN=token-forte-webhook
ASAAS_ENVIRONMENT=production
ASAAS_DISABLED=false
ASAAS_ONBOARDING_MODE=linked
ASAAS_ALLOW_MANUAL_WALLET=false
ASAAS_CREATE_SUBACCOUNT_ON_REGISTER=false
